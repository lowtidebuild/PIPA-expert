# PDF 원본 (전처리된 markdown이 library/에 있으므로 불필요)
PIPC Official Guidelines/

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# 벡터 DB (로컬 생성)
embeddings/chroma/

# 생성 결과물 (의견서 DOCX 등 — 폴더 구조는 유지, 내용물만 제외)
output/**
!output/
!output/opinions/
!output/opinions/.gitkeep

# 내부 설계 문서 (opaque private workspace)
/_private/**
!/_private/.gitkeep

# MCP 서버 설정 (API 키 포함)
.mcp.json

# 임시 파일
*.tmp

# 로컬 작업 로그
logs/local-worklog.md

# === 클라이언트 민감 문서 차단 ===
# .docx는 PIPA 자문 작업 결과물(의견서)이거나 클라이언트가 보낸 원본 문서.
# 어느 쪽이든 공개 GitHub 리포에 올라가면 안 되는 민감 정보를 포함할 수 있음.
# 향후 정당한 .docx를 추적해야 한다면 `git add -f <파일>`로 강제 추가 가능.
*.docx
